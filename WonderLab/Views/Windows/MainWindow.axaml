<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="WonderLab.Views.Windows.MainWindow"
        xmlns:vm="using:WonderLab.ViewModels"
        ExtendClientAreaTitleBarHeightHint="35"
        ExtendClientAreaToDecorationsHint="True"
        Title="WonderLab">
    <Panel>
        <NavigationPage IsBackButtonVisible="True" Name="RootNav" BarHeight="35"/>

        <Button Content="Click me!" VerticalAlignment="Center"
                HorizontalAlignment="Center"/>
    </Panel>
</Window>
