<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ma="using:Monet.Avalonia"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:dha="using:DialogHostAvalonia"
             x:Class="WonderLab.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->
  
    <Application.Styles>
        <ma:MonetColors/>
        <!-- <FluentTheme /> -->
        <mi:MaterialIconStyles/>
        <dha:DialogHostStyles/>
    </Application.Styles>

    <Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/UI/Themes/ScrollBar.axaml"/>
                <ResourceInclude Source="/UI/Themes/VisualTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/ButtonTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/SliderTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/WindowTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/TextBoxTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/ListBoxTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/ScrollViewer.axaml"/>
                <ResourceInclude Source="/UI/Themes/ComboBoxTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/TextBlockTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/PopupRootTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/DialogHostTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/ListBoxItemTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/RadioButtonTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/ContentPageTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/ToggleButtonTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/ComboBoxItemTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/ToggleSwitchTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/RippleControlTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/NavigationItemTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/NavigationRailTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/NavigationPageTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/MaterialWindowTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/FlyoutPresenterTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/SettingsCardItemTheme.axaml"/>
                <ResourceInclude Source="/UI/Themes/DialogOverlayPopupHostTheme.axaml"/>
                <!-- <ResourceInclude Source="/UI/Themes/WindowDrawnDecorationsTheme.axaml"/> -->
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>