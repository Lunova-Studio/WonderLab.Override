<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:wc="using:WonderLab.UI.Controls">
	<ControlTheme TargetType="wc:RippleControl" x:Key="{x:Type wc:RippleControl}">
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="RippleFill" Value="{DynamicResource RippleEffectFillBrush}"/>

		<Setter Property="Template">
			<ControlTemplate>
				<Border ClipToBounds="True"
						Background="{TemplateBinding Background}"
						BorderBrush="{TemplateBinding BorderBrush}"
						CornerRadius="{TemplateBinding CornerRadius}"
						BorderThickness="{TemplateBinding BorderThickness}">
					<Grid>					
						<ContentPresenter Name="PART_ContentPresenter"
						                  Content="{TemplateBinding Content}"
						                  Padding="{TemplateBinding Padding}"
						                  Foreground="{TemplateBinding Foreground}"
						                  CornerRadius="{TemplateBinding CornerRadius}"
						                  ContentTemplate="{TemplateBinding ContentTemplate}"
						                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
						                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"/>

						<Canvas IsHitTestVisible="False"
								VerticalAlignment="Stretch"
								HorizontalAlignment="Stretch"
								Name="PART_RippleCanvasRoot"/>
					</Grid>
				</Border>
			</ControlTemplate>
		</Setter>
	</ControlTheme>
</ResourceDictionary>