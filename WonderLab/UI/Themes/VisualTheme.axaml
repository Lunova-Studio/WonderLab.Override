<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--FontSize-->
    <x:Double x:Key="AppDefaultFontSize">12</x:Double>

    <!--CornerRadius-->
    <CornerRadius x:Key="NoneCornerRadius">0</CornerRadius>
    <CornerRadius x:Key="SmallCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="MediumCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="MaxCornerRadius">16</CornerRadius>
    <CornerRadius x:Key="FullCornerRadius">100</CornerRadius>

    <!--Brush-->
    <SolidColorBrush x:Key="RippleEffectFillBrush" Color="{DynamicResource InverseSurfaceColor}" Opacity="0.2"/>

    <SolidColorBrush x:Key="AppForegroundBrush" Color="{DynamicResource OnSurfaceColor}"/>
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{DynamicResource BackgroundColor}"/>

    <SolidColorBrush x:Key="AppTitleBarForegroundBrush" Color="{DynamicResource OnSurfaceVariantColor}"/>
    <SolidColorBrush x:Key="AppTitleBarBackgroundBrush" Color="{DynamicResource SurfaceContainerHighColor}"/>

    <SolidColorBrush x:Key="NavigationBarForegroundBrush" Color="{DynamicResource OnSurfaceVariantColor}"/>
    <SolidColorBrush x:Key="NavigationBarBackgroundBrush" Color="{DynamicResource SurfaceContainerHighColor}"/>

	<SolidColorBrush x:Key="ButtonFABBackgroundBrush" Color="{DynamicResource PrimaryContainerColor}"/>
    <SolidColorBrush x:Key="ButtonFABForegroundBrush" Color="{DynamicResource OnPrimaryContainerColor}"/>
    <SolidColorBrush x:Key="ButtonDefaultBorderBrush" Color="{DynamicResource SurfaceContainerHighColor}"/>
    <SolidColorBrush x:Key="ButtonDefaultForegroundBrush" Color="{DynamicResource OnSurfaceColor}"/>
	<SolidColorBrush x:Key="ButtonDefaultBackgroundBrush" Color="{DynamicResource InverseOnSurfaceColor}"/>
    <SolidColorBrush x:Key="ButtonDefaultPointerOverBackgroundBrush" Color="{DynamicResource InverseSurfaceColor}" Opacity="0.1"/>

	<SolidColorBrush x:Key="RadioButtonDefaultFillBrush" Color="{DynamicResource OnSurfaceVariantColor}"/>
	<SolidColorBrush x:Key="RadioButtonDefaultForegroundBrush" Color="{DynamicResource OnSurfaceColor}"/>
	<SolidColorBrush x:Key="RadioButtonCheckedDefaultFillBrush" Color="{DynamicResource PrimaryColor}"/>

    <SolidColorBrush x:Key="NavigationRailDefaultBackgroundBrush" Color="{DynamicResource SurfaceContainerColor}"/>

    <SolidColorBrush x:Key="NavigationItemDefaultForegroundBrush" Color="{DynamicResource OnSurfaceVariantColor}"/>
    <SolidColorBrush x:Key="NavigationItemSelectedForegroundBrush" Color="{DynamicResource OnSecondaryContainerColor}"/>
    <SolidColorBrush x:Key="NavigationItemSelectedBackgroundBrush" Color="{DynamicResource SecondaryContainerColor}"/>
    <SolidColorBrush x:Key="NavigationItemPointerOverBackgroundBrush" Color="{DynamicResource InverseSurfaceColor}" Opacity="0.1"/>
    <SolidColorBrush x:Key="NavigationItemSelectedPointerOverBackgroundBrush" Color="{DynamicResource OnSecondaryContainerColor}" Opacity="0.08"/>

    <SolidColorBrush x:Key="SettingsCardItemDefaultForegroundBrush" Color="{DynamicResource OnSurfaceColor}"/>
    <SolidColorBrush x:Key="SettingsCardItemDefaultBackgroundBrush" Color="{DynamicResource SurfaceContainerHighColor}"/>

</ResourceDictionary>