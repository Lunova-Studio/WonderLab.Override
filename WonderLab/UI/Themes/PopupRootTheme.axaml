<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ControlTheme x:Key="{x:Type PopupRoot}" TargetType="PopupRoot">
        <Setter Property="TransparencyLevelHint" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="{DynamicResource SmallCornerRadius}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
        <Setter Property="Background" Value="{DynamicResource PopupRootDefaultBackgroundBrush}"/>

        <Setter Property="Template">
            <ControlTemplate>
                <LayoutTransformControl LayoutTransform="{TemplateBinding Transform}">
                    <Panel>
                        <Border IsHitTestVisible="False"
                                Name="PART_TransparencyFallback"/>
                        
                        <VisualLayerManager Padding="4 0 4 4" Name="PART_VisualLayerManager">
                            <ContentPresenter Name="PART_ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              Padding="{TemplateBinding Padding}"
                                              Background="{TemplateBinding Background}"
                                              CornerRadius="{TemplateBinding CornerRadius}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}">
                            </ContentPresenter>
                        </VisualLayerManager>
                    </Panel>
                </LayoutTransformControl>
            </ControlTemplate>
        </Setter>

        <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
			<Style.Animations>
                <Animation Duration="0:0:.1"
                           FillMode="Forward"
                           Easing="CubicEaseOut">
					<KeyFrame Cue="0%">
						<Setter Property="Opacity" Value="0"/>
                        
                        <Setter Property="ScaleTransform.ScaleX" Value="0.2"/>
                        <Setter Property="ScaleTransform.ScaleY" Value="0.2"/>
                    </KeyFrame>

					<KeyFrame Cue="100%">
						<Setter Property="Opacity" Value="1"/>
                        
                        <Setter Property="ScaleTransform.ScaleX" Value="1"/>
                        <Setter Property="ScaleTransform.ScaleY" Value="1"/>
                    </KeyFrame>
                </Animation>

                <Animation Duration="0:0:.3"
                           Delay="0:0:.08"
                           FillMode="Forward"
                           Easing="CubicEaseOut">
					<KeyFrame Cue="0%">
						<Setter Property="Effect">
                            <DropShadowEffect OffsetX="0"
                                              OffsetY="1"
                                              Opacity="0"
                                              BlurRadius="5"
                                              Color="{DynamicResource PopupRootDefaultShadowBrush}"/>
                        </Setter>
                    </KeyFrame>

					<KeyFrame Cue="100%">
						<Setter Property="Effect">
                            <DropShadowEffect OffsetX="0"
                                              OffsetY="1"
                                              BlurRadius="5"
                                              Opacity="0.38"
                                              Color="{DynamicResource PopupRootDefaultShadowBrush}"/>
                        </Setter>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </ControlTheme>
</ResourceDictionary>
